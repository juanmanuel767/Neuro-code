paralelo {
    tarea {
        mostrar("   [Tarea 1] Iniciando...")
        esperar ia("Saluda en una palabra")
        mostrar("   [Tarea 1] Finalizada.")
    }
    tarea {
        mostrar("   [Tarea 2] Iniciando...")
        esperar ia("Despídete en una palabra")
        mostrar("   [Tarea 2] Finalizada.")
    }
}

