// 1. Variables y tipos
numero edad = 20
texto nombre = "Juan"
mostrar("Nombre: " + nombre)
mostrar("Edad en 5 años: " + a_texto(edad + 5))

// 2. Reactividad
mostrar("\n🧪 Probando Reactividad...")
reactivo contador = 0
cuando contador cambie {
    mostrar("   [Reactivo] El contador ahora es: " + a_texto(contador))
}

contador = 1
contador = 2

// 3. Constructor IA
mostrar("\n🏗️ Probando Constructor IA...")
constructor.crear_login()

