// Modulo estandar de pruebas de NeuroCode.

funcion afirmar(condicion, mensaje) {
    si no condicion {
        lanzar "FAIL: " + mensaje
    }
}

funcion igual(actual, esperado, mensaje) {
    si actual != esperado {
        lanzar "FAIL: " + mensaje + " (Esperado: " + texto(esperado) + ", Actual: " + texto(actual) + ")"
    }
}

exportar afirmar
exportar igual
