// Prueba de la librería neuro:web y el servidor integrado
depredactor neuro:pruebas como pruebas
depredactor neuro:web como web

imprimir("=================================")
imprimir("    TEST DE SERVIDOR WEB")
imprimir("=================================")

// Probar inicialización del servidor básico
servidor = esperar web.iniciar_servidor(3456)
tipo_servidor = tipo(servidor)
pruebas.igual(tipo_servidor, "servidor", "iniciar_servidor retorna un objeto ServidorWeb nativo")

