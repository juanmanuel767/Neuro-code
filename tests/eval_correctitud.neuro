usar "tests/eval_framework.neuro" como fw

imprimir("=================================")
imprimir("   TEST DE CORRECTITUD AQUILA")
imprimir("=================================")

// 1. Asignaciones y Operadores
a = 10
b = 20
fw.afirmar_igual(a + b, 30, "Suma básica")
fw.afirmar_igual(b - a, 10, "Resta básica")
fw.afirmar(a < b, "Operador Menor Que")
fw.afirmar(a == 10 y b == 20, "Operador Y Lógico")
fw.afirmar(a == 99 o b == 20, "Operador O Lógico")

// 2. Control de Flujo (Si/Sino)
x = falso
si a > 5 {
    x = verdadero
}
fw.afirmar_igual(x, verdadero, "Condicional Si")

// 3. Bucles
suma_bucle = 0
mientras suma_bucle < 50 {
    suma_bucle = suma_bucle + 10
}
fw.afirmar_igual(suma_bucle, 50, "Bucle Mientras")

suma_para = 0
lista_num = [1, 2, 3, 4]
para n en lista_num {
    suma_para = suma_para + n
}
fw.afirmar_igual(suma_para, 10, "Bucle Para")

// 4. Funciones
funcion recursiva(n) {
    si n <= 1 {
        retornar 1
    }
    retornar n * recursiva(n - 1)
}
fw.afirmar_igual(recursiva(5), 120, "Recursividad (Factorial de 5)")

// 5. Manejo de Errores (Intentar / Capturar)
error_capturado = falso
intentar {
    res = 10 / 0
} capturar e {
    error_capturado = verdadero
}
fw.afirmar_igual(error_capturado, verdadero, "Captura de división por cero")

index_error = falso
intentar {
    mal = lista_num[10]
} capturar e {
    index_error = verdadero
}
fw.afirmar_igual(index_error, verdadero, "Captura de Out-Of-Bounds para Listas")

// 6. OOP Básico
clase Perro {
    funcion crear(n) {
        esto.nombre = n
    }
    funcion ladrar() {
        retornar esto.nombre + " hace guau"
    }
}
p = nuevo Perro("Max")
fw.afirmar_igual(p.ladrar(), "Max hace guau", "OOP: Método y Propiedad")

imprimir("✅ ¡TODAS LAS PRUEBAS DE CORRECTITUD PASARON!")
