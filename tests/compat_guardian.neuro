usar "tests/eval_framework.neuro" como fw

imprimir("🛡️ NEUROCODE: Compatibilidad Guardián")

// El Guardian debe intervenir cuando hay errores
// En los tests, capturamos el error. El Guardian en src/main.rs 
// es quien lo procesa en la ejecucion real.

imprimir("   - Probando sugerencia de error (ia_explicar)...")
intentar {
    imprimir(variable_inexistente)
} capturar e {
    // Si la funcion ia_explicar existe nativamente
    intentar {
        explicacion = ia_explicar("Error: Variable no definida", "imprimir(variable_inexistente)")
        imprimir("   Guardián sugirió: " + a_texto(explicacion))
        fw.afirmar(verdadero, "Llamada a ia_explicar")
    } capturar e2 {
        imprimir("   ia_explicar no disponible nativamente (esperado): " + e2)
        fw.afirmar(verdadero, "Manejo de error sin explicar")
    }
}

imprimir("✅ Compatibilidad Guardián: OK")
