usar "eval_framework.neuro" como fw

imprimir("=================================")
imprimir("      TEST DE JSON NATIVO")
imprimir("=================================")

datos = json_parsear('{"usuario":{"nombre":"NeuroCode","activo":true},"puntos":[10,20,30],"total":60}')

fw.afirmar_igual(datos["usuario"]["nombre"], "NeuroCode", "JSON: acceso a objeto anidado")
fw.afirmar_igual(datos["usuario"]["activo"], verdadero, "JSON: booleano")
fw.afirmar_igual(datos["puntos"][1], 20, "JSON: lista")
fw.afirmar_igual(datos["total"], 60, "JSON: entero")

salida = json_texto({
    "lenguaje": "NeuroCode",
    "potente": verdadero,
    "niveles": [1, 2, 3]
})

redondo = json_parsear(salida)
fw.afirmar_igual(redondo["lenguaje"], "NeuroCode", "JSON: serializar y parsear texto")
fw.afirmar_igual(redondo["niveles"][2], 3, "JSON: conservar listas al serializar")

imprimir("✅ JSON NATIVO OK")
