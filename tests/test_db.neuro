asincrono funcion principal() {
    imprimir("===============================")
    imprimir(" TEST: BASE DE DATOS NATIVA")
    imprimir("===============================")
    
    imprimir("1. Conectando a disco (prueba.db)...")
    db = nuevo BaseDatos("prueba.db")
    
    imprimir("2. Creando tabla secreta...")
    esperar db.ejecutar("CREATE TABLE IF NOT EXISTS misiones (id INTEGER PRIMARY KEY, nombre TEXT, estado TEXT)")
    
    // Limpiamos datos viejos si lo corremos varias veces
    esperar db.ejecutar("DELETE FROM misiones")
    
    imprimir("3. Insertando registros asíncronos...")
    esperar db.ejecutar("INSERT INTO misiones (nombre, estado) VALUES (?, ?)", ["Colonizar Marte", "En Progreso"])
    esperar db.ejecutar("INSERT INTO misiones (nombre, estado) VALUES (?, ?)", ["Desarrollar NeuroCode", "Completado"])
    
    imprimir("4. Consultando los datos insertados...")
    resultados = esperar db.consultar("SELECT * FROM misiones")
    
    imprimir("Misiones extraídas de la DB:")
    imprimir(resultados)
    
    imprimir("===============================")
}

esperar principal()
